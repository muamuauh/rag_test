# =====================================================
# 复制本文件为 .env，并填入真实 key。.env 已被 .gitignore
# =====================================================
#
# 三元组模式：每个云端角色（LLM / VLM / Embedding）独立配置
#   {ROLE}_MODEL    = LiteLLM 标准模型名
#   {ROLE}_API_KEY  = 该 provider 的 API key（留空则 fallback 到下方"标准 env"）
#   {ROLE}_BASE_URL = 自定义端点（聚合服务 / 自部署网关填这个；直连官方留空）
#
# 接 OpenAI-compatible 聚合服务（AIHubMix / OpenRouter / OneAPI / vLLM 自部署...）：
#   _MODEL 写成 openai/<聚合侧模型ID>，_BASE_URL 填聚合服务地址
#   前缀 openai/ 告诉 LiteLLM 走 OpenAI-style 协议
#
# 各场景照着下面任选一个 Profile 改即可：
# =====================================================


# ===================== Profile A：直连官方 =====================
# LLM_MODEL=openai/gpt-4o-mini
# LLM_API_KEY=                        # 留空则读 OPENAI_API_KEY
# LLM_BASE_URL=                       # 留空 = 官方端点
#
# VLM_MODEL=openai/gpt-4o-mini
# VLM_API_KEY=
# VLM_BASE_URL=
#
# OPENAI_API_KEY=sk-...               # 三元组留空时 LiteLLM 会用这个


# ===================== Profile B：AIHubMix =====================
# LLM_MODEL=openai/claude-sonnet-4.5  # AIHubMix 模型 ID 直接照抄官方名
# LLM_API_KEY=sk-aihub-xxx
# LLM_BASE_URL=https://aihubmix.com/v1
#
# VLM_MODEL=openai/gpt-4o
# VLM_API_KEY=sk-aihub-xxx            # 同 key 同端点直接复用
# VLM_BASE_URL=https://aihubmix.com/v1


# ===================== Profile C：OpenRouter =====================
# LLM_MODEL=openai/anthropic/claude-sonnet-4.5  # OR 是 provider/model 双段
# LLM_API_KEY=sk-or-v1-xxx
# LLM_BASE_URL=https://openrouter.ai/api/v1
#
# VLM_MODEL=openai/openai/gpt-4o
# VLM_API_KEY=sk-or-v1-xxx
# VLM_BASE_URL=https://openrouter.ai/api/v1


# ===================== Profile D：本地 Ollama VLM（VLM 专用） =====================
# 适合：想 VLM 完全离线 / 零 API 费 / 无 rate limit
# 前置：
#   1. 装 Ollama: https://ollama.com/download
#   2. 拉模型:    ollama pull qwen2.5vl:3b   (3B ~3GB 显存) 或 qwen2.5vl:7b (7B ~6GB)
#   3. 系统环境变量加 OLLAMA_NUM_PARALLEL=2 让 ingest 并发能用上
# 注意：LLM 通常仍走云端（本地小模型推理质量不如 GPT/Claude），所以只切 VLM_*
#
# VLM_MODEL=openai/qwen2.5vl:3b               # openai/ 前缀 = OpenAI-compat 协议
# VLM_API_KEY=ollama                           # Ollama 不校验，但 LiteLLM 要非空
# VLM_BASE_URL=http://localhost:11434/v1


# ===================== 实际生效的配置（去掉注释后会被加载） =====================

LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=

VLM_MODEL=openai/gpt-4o-mini
VLM_API_KEY=
VLM_BASE_URL=
# VLM 全局限速（请求/秒），0 或留空 = 不限速。
# OpenAI Tier 1 gpt-4o-mini (200K TPM / 500 RPM) 推荐 5；本地 Ollama 留空。
VLM_MAX_RPS=0


# ---------- 标准 provider key（向后兼容；三元组留空时 LiteLLM 会读这些） ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZHIPUAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# OPENAI_BASE_URL=                    # 直连 OpenAI 时若用代理可填


# ---------- Embedding ----------
# provider:
#   local = 本地 BGE-M3，输出 dense + sparse 双路（推荐：隐私、离线、无 API 成本）
#   cloud = LiteLLM 调云端 dense embedding + Milvus 内置 BM25 自动生成 sparse
EMBEDDING_PROVIDER=local

# --- local 模式参数 ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu        # cpu / cuda
USE_FP16=false              # cuda 上可设 true

# --- cloud 模式参数（注意：聚合服务通常不提供 embedding，建议 embedding 直连 OpenAI 等）---
# 推荐 provider 与对应维度：
#   openai/text-embedding-3-small  → 1536
#   openai/text-embedding-3-large  → 3072
#   zhipu/embedding-3              → 2048
#   dashscope/text-embedding-v3    → 1024
#   jina_ai/jina-embeddings-v3     → 1024
CLOUD_EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_API_KEY=                     # 留空 = 走 OPENAI_API_KEY
EMBEDDING_BASE_URL=                    # 留空 = 直连官方
EMBEDDING_DIM=1536                     # 切 cloud 时必须改成与模型一致

# Milvus BM25 分词器（cloud 模式生效）：
#   standard = 通用，适合中英混合（中文按字符切）
#   chinese  = jieba 中文分词，纯中文知识库选这个
#   english  = 英文分词
MILVUS_ANALYZER=standard


# ---------- Reranker (始终本地，模型小且效果敏感) ----------
RERANKER_MODEL=BAAI/bge-reranker-v2-m3


# ---------- Milvus ----------
# Windows 用户：milvus-lite 无 Windows 支持，请用 Docker 跑 Standalone：
#   .\standalone.bat start  （或 docker compose up -d）
# Linux/macOS 可填本地路径："./data/milvus/rag_test.db" 走 milvus-lite
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=rag_chunks


# ---------- 切分参数 ----------
CHUNK_SIZE=512
CHUNK_OVERLAP=64


# ---------- 检索参数 ----------
RETRIEVE_TOP_K=30
RERANK_TOP_K=5


# ---------- 路径 ----------
DATA_RAW_DIR=./data/raw
DATA_IMAGES_DIR=./data/images
