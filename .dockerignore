# 不要把这些拷进镜像（保持镜像小、避免泄密）
.git/
.gitignore
.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
.idea/
.vscode/

# 关键：API key 不能进镜像
.env

# 用户数据走 volume / bind mount，不进镜像
data/
volumes/
embedEtcd.yaml
user.yaml
standalone.bat

# 本地 HF 缓存走 named volume，不进镜像
.cache/
hf_cache/

# 文档/README 不影响运行，可选忽略
*.md
!app/**/*.md
